// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  email          String    @unique
  hashedPassword String? // OAuth 사용자는 비밀번호가 없을 수 있음
  name           String?
  school         String?
  region         String? // 지역 정보
  role           String? // "student", "teacher", "admin", 또는 "superadmin"
  emailVerified  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Password reset
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // Email verification
  verificationToken   String?
  verificationExpires DateTime?

  // Relations
  accounts       Account[]
  sessions       Session[]
  classes        Course[]        @relation("TeacherCourses")
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  adminProfile   AdminProfile?
  parentProfile  ParentProfile?
  createdSchools School[]        @relation("SchoolCreator") // 슈퍼어드민이 생성한 학교
  adminSchools   School[]        @relation("SchoolAdminUser") // Admin이 담당하는 학교
  teacherBanner  TeacherBanner?  @relation("TeacherBanners")
  comments       Comment[]       // 댓글

  @@map("users")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum CourseType {
  regular
  after_school
}

model Course {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  courseType          CourseType           @default(regular)
  academicYear        String               @default("")
  semester            String               @default("")
  subjectGroup        String               @default("")
  subjectArea         String               @default("")
  careerTrack         String               @default("")
  subject             String
  grade               String
  instructor          String
  classroom           String
  description         String               @default("")
  joinCode            String?
  enrollmentOpen      Boolean              @default(true)
  teacherId           String?              @db.ObjectId
  teacher             User?                @relation("TeacherCourses", fields: [teacherId], references: [id], onDelete: SetNull)
  assignments         Assignment[]
  evaluationQuestions EvaluationQuestion[]
  classGroups         ClassGroup[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@map("classes")
}

model PeriodSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  start     DateTime?
  end       DateTime?
  updatedBy String?  @db.ObjectId
  updatedAt DateTime @default(now()) @updatedAt

  @@map("period_settings")
}

model Assignment {
  id               String                 @id @default(auto()) @map("_id") @db.ObjectId
  title            String
  description      String?
  filePath         String? // 서버에 저장된 파일 경로
  originalFileName String? // 원본 파일명
  fileSize         Int? // 파일 크기 (bytes)
  mimeType         String? // 파일 MIME 타입
  dueDate          DateTime? // 마감일 (선택적)
  courseId         String                 @db.ObjectId
  course           Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId        String                 @db.ObjectId
  viewCount        Int                    @default(0) // 조회수
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  attachments      AssignmentAttachment[] // 다중 첨부파일

  @@map("assignments")
}

model AssignmentAttachment {
  id               String     @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId     String     @db.ObjectId
  assignment       Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  filePath         String
  originalFileName String
  fileSize         Int?
  mimeType         String?
  createdAt        DateTime   @default(now())

  @@map("assignment_attachments")
}

model EvaluationQuestion {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  unit           String // 평가 단원
  questionNumber String // 문제 비밀번호
  questions      String // JSON 배열로 저장된 문항들
  courseId       String   @db.ObjectId
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacherId      String   @db.ObjectId
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("evaluation_questions")
}

model ScoreRelease {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  evaluationQuestionId  String   @db.ObjectId
  courseId              String   @db.ObjectId
  released              Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([evaluationQuestionId])
  @@map("score_releases")
}

model EvaluationSubmission {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  evaluationQuestionId  String   @db.ObjectId
  courseId              String   @db.ObjectId
  studentId             String   @db.ObjectId
  answers               String   // JSON: [{ index, type, answer, correctAnswer?, score? }]
  totalScore            Int?
  graded                Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([evaluationQuestionId])
  @@index([studentId])
  @@map("evaluation_submissions")
}

model ClassGroup {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String // 학반명
  period      String? // 차시
  schedules   String // JSON 배열로 저장된 스케줄 (요일과 교시)
  courseId    String       @db.ObjectId
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studentIds  String[] // 학생 ID 배열
  teacherId   String       @db.ObjectId
  attendances Attendance[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("class_groups")
}

model Attendance {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  classGroupId String     @db.ObjectId
  classGroup   ClassGroup @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  studentId    String     @db.ObjectId
  date         DateTime // 출결 날짜
  status       String // 출결 상태: "present", "late", "sick_leave", "approved_absence", "excused"
  teacherId    String     @db.ObjectId
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([classGroupId, studentId, date])
  @@map("attendances")
}

model StudentProfile {
  id                         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                     String   @unique @db.ObjectId
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentId                  String?
  school                     String?
  grade                      String?
  classLabel                 String?
  section                    String?
  seatNumber                 String?
  major                      String?
  sex                        String?
  classOfficer               String?
  specialEducation           String?
  phoneNumber                String?
  siblings                   String?
  academicStatus             String?
  remarks                    String?
  club                       String?
  clubTeacher                String?
  clubLocation               String?
  dateOfBirth                String?
  address                    String?
  residentRegistrationNumber String?
  motherName                 String?
  motherPhone                String?
  motherRemarks              String?
  fatherName                 String?
  fatherPhone                String?
  fatherRemarks              String?
  electiveSubjects           String[]
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@map("student_profiles")
}

model TeacherProfile {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @unique @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school       String?
  roleLabel    String?
  major        String?
  classLabel   String?
  grade        String?
  section      String?
  phoneNumber  String?
  remarks      String?
  club         String?
  clubLocation String?
  dateOfBirth  String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("teacher_profiles")
}

model CalendarEvent {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  title             String
  description       String?
  startDate         DateTime
  endDate           DateTime?
  eventType         String?   @default("기타") // "평가", "행사", "휴업일", "개인일정", "기타"
  scope             String // "school" | "personal" | "class"
  school            String? // scope가 "school"일 때 학교 필터링
  teacherId         String?   @db.ObjectId // 개인일정일 때
  courseId          String?   @db.ObjectId // 수업별 일정일 때
  department        String? // 담당 부서
  responsiblePerson String? // 담당자
  scheduleArea      String? // 일정 구분: "창의적 체험활동", "교과"
  gradeLevels       String[]  @default([])
  periods           String[]  @default([])
  createdBy         String    @db.ObjectId // 생성한 사용자 ID
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([scope, school])
  @@index([teacherId])
  @@index([startDate])
  @@map("calendar_events")
}

model Announcement {
  id                    String             @id @default(auto()) @map("_id") @db.ObjectId
  title                 String
  category              String? // "notice", "survey", "consent" (단순 알림, 설문 조사, 동의서)
  content               String // HTML 형식의 본문
  courseId              String?            @db.ObjectId // 수업별 공지사항
  selectedClassGroupIds String[]           @default([]) // 수업 학반 대상 (classGroup IDs)
  boardType             String? // 예: "board_test"
  audience              String // "all", "grade-1", "grade-2", "grade-3", "parents", "teacher", "students"
  author                String // 작성자 이름
  authorId              String             @db.ObjectId // 작성자 User ID
  isScheduled           Boolean            @default(false)
  publishAt             DateTime? // 예약 발행 시각
  publishedAt           DateTime? // 실제 발행 시각
  school                String? // 학교 필터링
  selectedClasses       String? // 재학생 학급 선택 정보 (JSON 배열)
  parentSelectedClasses String? // 학부모 학급 선택 정보 (JSON 배열)
  surveyData            String? // 설문 조사 질문 데이터 (JSON 배열)
  surveyStartDate       DateTime? // 설문 조사 시작일시
  surveyEndDate         DateTime? // 설문 조사 종료일시
  consentData           String? // 동의서 서명 데이터 (JSON 객체: {signatureImage: string, signedAt?: string})
  consentStats          String? // 동의서 통계 캐시 (JSON: {totalStudents, totalParents, updatedAt})
  attachments           String? // 첨부 파일 데이터 (JSON 배열: [{filePath, originalFileName, fileSize, mimeType}])
  viewCount             Int                @default(0) // 조회수
  editableBy            String[]           @default([]) // 수정 권한을 가진 교사 ID 배열
  lastEditedBy          String?            @db.ObjectId // 마지막으로 수정한 사용자 ID (원래 작성자가 아닌 경우)
  lastEditedByName      String? // 마지막으로 수정한 사용자 이름
  views                 AnnouncementView[] // 조회 이력
  consents              AnnouncementConsent[] // 동의서 서명 이력
  surveyResponses       AnnouncementSurveyResponse[] // 설문 응답 이력
  comments              Comment[]          // 댓글
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([audience])
  @@index([boardType])
  @@index([courseId])
  @@index([authorId])
  @@index([publishAt])
  @@index([publishedAt])
  @@map("announcements")
}

model AnnouncementConsent {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  announcementId String       @db.ObjectId
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String       @db.ObjectId
  signatureImage String?      // 이전 base64 서명 데이터 (레거시)
  signatureUrl   String?      // Blob 저장된 서명 이미지 URL
  signedAt       DateTime     @default(now())
  submittedAt    DateTime?    // 제출 일시 (제출 후 재제출 금지)
  returnedAt     DateTime?    // 담당자 반환 일시
  returnReason   String?      // 반환 사유 (선택)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
  @@map("announcement_consents")
}

model AnnouncementSurveyResponse {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  announcementId String       @db.ObjectId
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String       @db.ObjectId
  answers        String       // JSON: [{ id: string, answer: string | string[] }]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
  @@map("announcement_survey_responses")
}

model AnnouncementView {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  announcementId String       @db.ObjectId
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String       @db.ObjectId
  viewedAt       DateTime     @default(now())

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@index([userId])
  @@map("announcement_views")
}

model School {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  name          String // 학교 이름
  adminUserId   String         @db.ObjectId // 담당 Admin 계정 ID
  admin         User           @relation("SchoolAdminUser", fields: [adminUserId], references: [id], onDelete: Cascade)
  createdBy     String?        @db.ObjectId // 생성한 슈퍼어드민 ID
  creator       User?          @relation("SchoolCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  adminProfiles AdminProfile[] // AdminProfile과의 관계

  logoUrl String? // 학교 대표 로고 이미지 URL

  // 학교 구분
  schoolType String @default("기타") // "초등학교", "중학교", "고등학교", "대학교", "기타"

  // 담당자 정보
  contactName  String // 스쿨허브 담당자 이름
  contactPhone String // 담당자 전화번호

  // 학교 규모 정보 (학년별 학급수 및 총 학생수)
  gradeInfo     String // JSON 형식: [{grade: "1", classCount: 5, studentCount: 150}, ...]
  totalClasses  Int? // 총 학급수 (계산된 값)
  totalStudents Int? // 총 학생수 (계산된 값)

  status String  @default("active") // "active", "inactive", "suspended"
  notes  String? // 메모

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminUserId])
  @@index([createdBy])
  @@index([status])
  @@map("schools")
}

model AdminProfile {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @unique @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId    String?  @db.ObjectId
  school      School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  phoneNumber String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@map("admin_profiles")
}

model ParentProfile {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @unique @db.ObjectId
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentIds   String[] // 자녀 학생들의 User ID 배열
  phoneNumber  String?
  relationship String? // "mother", "father", "guardian" 등
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("parent_profiles")
}

model TeacherBanner {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  teacherId String   @unique @db.ObjectId
  user      User     @relation("TeacherBanners", fields: [teacherId], references: [id], onDelete: Cascade)
  banners   String   @default("[]") // JSON 배열: [{icon: "BookOpen", title: "수업 관리", url: "/dashboard/teacher/manage-classes"}, ...]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("teacher_banners")
}

model Comment {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  announcementId String       @db.ObjectId
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  authorId       String       @db.ObjectId
  author         User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content        String       // 댓글 내용
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  parentId       String?      @db.ObjectId // 대댓글을 위한 부모 댓글 ID
  parent         Comment?     @relation("CommentReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies        Comment[]    @relation("CommentReplies") // 대댓글 목록

  @@index([announcementId])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

model AfterSchoolCourseRequest {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  courseName     String   // 희망 강좌명
  desiredContent String   // 듣고 싶은 내용
  notes          String?  // 비고
  companionStudents String? // 함께 신청하는 학생 (표시용: "학번 이름, 학번 이름")
  companionStudentUserIds String[] @default([]) // 함께 신청하는 학생 userId 목록 (id 기반)
  studentId      String   @db.ObjectId // 신청한 학생 ID
  studentName   String   // 신청한 학생 이름
  school         String?  // 학교
  status         String   @default("pending") // "pending", "approved", "rejected"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([studentId])
  @@index([school])
  @@index([status])
  @@index([createdAt])
  @@map("after_school_course_requests")
}

model CleaningArea {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  classGroup   String   // 학반 (예: 1-1)
  area         String   // 담당구역 (예: 복도 A구역)
  teacher      String   // 지도교사
  studentCount Int?     // 학생수 (권장)
  studentIds   String[] @default([]) // 선택된 학생 ID 배열
  notes        String?  // 비고
  school       String?  // 학교
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([school])
  @@index([classGroup])
  @@map("cleaning_areas")
}

model CleaningAreaMap {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  school       String   @unique // 학교별 청소구역 배치도 1장
  imageUrl     String?  // Vercel Blob Storage URL (선택)
  guideContent String?  // 청소안내 내용 (일반 텍스트)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("cleaning_area_maps")
}

model Volunteer {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  type              String   // "homeroom" | "manager" (담임 선발 | 담당자 선발)
  department        String   // 부서명
  teacher           String   // 담당교사
  activityName      String   // 봉사활동명
  activityContent   String?  // 활동 내용
  volunteerArea     String?  // 봉사 영역
  startDate         DateTime? // 시작 날짜
  endDate           DateTime? // 종료 날짜
  grade             String?  // 활동 학년
  selectionCount    Int?     // 선발 인원
  volunteerHours    Int?     // 봉사 시간
  location          String?  // 활동 장소
  studentSelections String?  // 학반별 학생 선택 정보 (JSON 문자열: { "classLabel": ["studentId1", "studentId2", ...] })
  school            String?  // 학교
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([school])
  @@index([type])
  @@index([teacher])
  @@map("volunteers")
}

model Club {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  clubName          String   // 동아리명
  teacher           String   // 담당교사
  category          String?  // 구분: 인문, 사회, 수학, 과학, 어학, 독서*토론, 음악, 미술, 체육, 댄스, 기타
  clubType          String   // "creative" | "autonomous" (창체 동아리 | 자율 동아리)
  description       String?  // 설명
  maxMembers        Int?     // 정원
  location          String?  // 활동 장소
  studentSelections String?  // 학반별 학생 선택 정보 (JSON 문자열: { "classLabel": ["studentId1", "studentId2", ...] })
  school            String?  // 학교
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([school])
  @@index([clubType])
  @@index([teacher])
  @@map("clubs")
}
